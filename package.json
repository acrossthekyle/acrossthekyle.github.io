{
  "name": "acrossthekyle",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://acrossthekyle.com",
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "echo 'acrossthekyle.com' > ./build/CNAME && cp 404.html build/404.html && gh-pages -d build",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --watchAll=false --testPathIgnorePatterns=.*e2e.test.js",
    "test:e2e": "react-scripts test --watchAll=false --testPathPattern=.*e2e.test.js"
  },
  "dependencies": {
    "@types/jest": "^29.5.3",
    "@types/node": "^20.5.0",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "gh-pages": "^3.2.3",
    "lodash": "^4.17.21",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intersection-observer": "^9.8.1",
    "react-router-dom": "^6.3.0",
    "react-scripts": "^5.0.1",
    "react-swipeable": "7.0.1",
    "sass": "^1.71.1",
    "typescript": "^5.1.6"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.198",
    "puppeteer": "18.1.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
